# === 後端系統 ===
SYSTEM_URL=https://your-service-url.a.run.app
# 觸發密鑰：不填則自動讀同目錄 secret.txt
AUTO_TRIGGER_SECRET=

# === 寄信（SMTP；Gmail 範例：smtp.gmail.com:587 + 應用程式密碼） ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=your@gmail.com

# === 收件人 ===
# 管理者：異常警報 + 每日日報
ADMIN_EMAILS=admin@example.com
# 結果收件人：完成的會議字幕（未設定則寄管理者）
RESULT_EMAILS=user1@example.com,user2@example.com
