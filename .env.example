GEMINI_API_KEY=your_gemini_api_key_here
# 多把 Key 輪替（逗號分隔），設定後優先於 GEMINI_API_KEY
GEMINI_API_KEYS=key1,key2,key3
# 翻譯模型，預設 gemini-3.5-flash
GEMINI_MODEL=gemini-3.5-flash
BUCKET_NAME=your_gcs_bucket_name_here
ALLOWED_ORIGINS=https://your-domain.com,https://your-app.run.app

# --- 自動錄製 / Automation ---
# 觸發 /auto_record_check 所需的共享密鑰；未設定則該端點回 503（功能停用）
AUTO_TRIGGER_SECRET=your_long_random_secret_here
# 自動錄製/補抓 VOD 時的預設參數
AUTO_RECORD_MODE=speech
AUTO_RECORD_DIARIZE=false
AUTO_RECORD_KNOWN_NAMES=
